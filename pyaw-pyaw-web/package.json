  "dependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "@types/leaflet": "^1.9.21",
    "leaflet": "^1.9.4",
    "mqtt": "^5.15.0",
    "peerjs": "^1.5.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-leaflet": "^5.0.0",
    "react-scripts": "^5.0.1",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "predeploy": "node -e \"const fs=require('fs');try{fs.rmSync('node_modules/.cache/gh-pages',{recursive:true,force:true});}catch(error){if(error.code!=='EPERM'&&error.code!=='ENOENT'){throw error;}}\" && npm run build",
    "deploy": "gh-pages -b gh-pages -d build -r https://github.com/ThantHtetMyet/pyaw-pyaw.git",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "gh-pages": "^6.2.0"
  }
}
